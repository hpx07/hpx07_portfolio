# ── Database ────────────────────────────────────────────────
# Dialect: mysql | postgres | sqlite
DB_DIALECT=mysql

# MySQL / MariaDB (XAMPP defaults shown)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hpx_v2

# PostgreSQL — either discrete vars for a local server…
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=hpx_v2
# …or a single connection string for hosted Postgres (Supabase / Neon / Vercel Postgres).
# When one of these is present, DB_DIALECT auto-switches to postgres and TLS is enabled,
# so you don't need to set DB_DIALECT. Vercel's Supabase integration injects POSTGRES_URL
# automatically in production — nothing to add there.
# POSTGRES_URL=postgres://user:password@host:6543/postgres?sslmode=require

# SQLite (file path, used when DB_DIALECT=sqlite)
SQLITE_FILE=./database/hpx_v2.sqlite

# ── Admin auth ──────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-now
# Long random string used to sign session cookies
AUTH_SECRET=generate-a-long-random-string-here

# ── Site ────────────────────────────────────────────────────
SITE_URL=http://localhost:3000

# Optional: Google PageSpeed Insights API key (works without one at low quota)
PSI_API_KEY=
